# Database Configuration

# Option 1: Full DATABASE_URL (for local development)
DATABASE_URL=mysql+pymysql://appuser:apppassword@mysql:3306/simpledb

# Option 2: Individual components (for ECS with Secrets Manager)
# ECS will inject DB_USERNAME and DB_PASSWORD from Secrets Manager at runtime
# DB_USERNAME=appuser          # Injected from Secrets Manager in ECS
# DB_PASSWORD=apppassword      # Injected from Secrets Manager in ECS
# DB_HOST=your-rds-endpoint.region.rds.amazonaws.com
# DB_PORT=3306
# DB_NAME=simpledb
